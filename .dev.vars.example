# Copy to .dev.vars for local wrangler dev (never commit .dev.vars)

ENVIRONMENT=development

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

SENTRY_DSN=

DUITKU_BASE_URL=https://sandbox.duitku.com
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_CALLBACK_SECRET=

PAYCORE_PUBLIC_BASE_URL=http://localhost:8787
PAYCORE_INTERNAL_MASTER_KEY=change_me_32_chars_minimum________
PAYCORE_ENCRYPTION_KEY=change_me_32_byte_key_base64______

# App credentials (Key ID -> secret mapping resolved in env)
NARRAZA_APP_KEY_ID=pk_dev_narraza_01
NARRAZA_APP_SECRET=dev_narraza_app_secret_change_me
NARRAZA_WEBHOOK_SECRET=dev_narraza_webhook_secret_change_me

# Admin (Cloudflare Access JWT in production; dev bypass header)
PAYCORE_ADMIN_DEV_TOKEN=dev_admin_token_change_me