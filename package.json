{
  "name": "appvibe-paycore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:migrate:local": "wrangler d1 migrations apply paycore-staging --local",
    "db:migrate:staging": "wrangler d1 migrations apply paycore-staging --remote --env staging",
    "db:migrate:production": "wrangler d1 migrations apply paycore-production --remote --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.4",
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.18",
    "@cloudflare/workers-types": "^4.20250317.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9",
    "wrangler": "^4.0.0"
  }
}